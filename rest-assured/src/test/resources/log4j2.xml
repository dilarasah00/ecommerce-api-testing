<?xml version="1.0" encoding="UTF-8"?>
<Configuration packages="org.apache.logging.log4j.core">
    <Properties>
        <Property name="logPattern">%d{yyyy-MM-dd HH:mm:ss} [%-5p] [%t] %c{1} - %m%n</Property>
        <Property name="logDir">logs</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender for immediate visibility -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="${logPattern}"/>
        </Console>

        <!-- File Appender for test execution logs -->
        <File name="FileAppender" fileName="${logDir}/automation-tests.log">
            <PatternLayout pattern="${logPattern}"/>
        </File>

        <!-- Async Appender for performance optimization -->
        <Async name="AsyncFileAppender">
            <AppenderRef ref="FileAppender"/>
        </Async>
    </Appenders>

    <Loggers>
        <!-- Root logger -->
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="AsyncFileAppender"/>
        </Root>

        <!-- Project-specific loggers -->
        <Logger name="com.company.project" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="AsyncFileAppender"/>
        </Logger>

        <!-- Rest-Assured logger -->
        <Logger name="io.restassured" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="AsyncFileAppender"/>
        </Logger>

        <!-- Database operations logger -->
        <Logger name="com.company.project.utilities.DBUtils" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="AsyncFileAppender"/>
        </Logger>

        <!-- JUnit logger -->
        <Logger name="org.junit.jupiter" level="INFO" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="AsyncFileAppender"/>
        </Logger>
    </Loggers>
</Configuration>
